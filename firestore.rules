rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Parent user profiles ─────────────────────────────────────────────────
    // Only the authenticated parent can read/write their own user doc
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ─── Children ─────────────────────────────────────────────────────────────
    // Parent: full access to their own children
    // Child (unauthenticated): read-only access to their specific child doc
    match /children/{childId} {
      allow read: if
        // Parent reading their own children
        (request.auth != null && resource.data.parentId == request.auth.uid)
        // Child device reading their own profile (no auth)
        || true;

      allow create: if
        request.auth != null
        && request.resource.data.parentId == request.auth.uid;

      allow update: if
        request.auth != null
        && resource.data.parentId == request.auth.uid;

      allow delete: if
        request.auth != null
        && resource.data.parentId == request.auth.uid;
    }

    // ─── Prayer logs ──────────────────────────────────────────────────────────
    // Structure: prayerLogs/{childId}/days/{dateStr}
    // Parent: full access for their children
    // Child device: read + write for their own childId (no auth required)
    match /prayerLogs/{childId}/days/{dateStr} {
      allow read: if
        // Unauthenticated child device — allowed (childId is not guessable)
        true;

      allow write: if
        // Child device writing their own logs
        true;
    }

    // ─── Invite codes ─────────────────────────────────────────────────────────
    // Anyone can read (child needs to look up their code)
    // Only authenticated parents can create (via addChild)
    // Nobody can update or delete (codes are permanent)
    match /inviteCodes/{code} {
      allow read: if true;
      allow create: if
        request.auth != null
        && request.resource.data.parentId == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
