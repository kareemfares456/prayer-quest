rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Parent user profiles ─────────────────────────────────────────────────
    // Only the authenticated parent can read/write their own user doc
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ─── Children ─────────────────────────────────────────────────────────────
    // GET  — parent (auth) or child device (knows UUID stored on device)
    // LIST — authenticated parent only (prevents bulk data harvesting)
    // WRITE — authenticated parent owning the child only
    match /children/{childId} {
      allow get: if
        (request.auth != null && resource.data.parentId == request.auth.uid)
        // Child device fetches its own doc by UUID — guessing a UUID is impractical
        || true;

      allow list: if
        request.auth != null;

      allow create: if
        request.auth != null
        && request.resource.data.parentId == request.auth.uid;

      allow update: if
        request.auth != null
        && resource.data.parentId == request.auth.uid;

      allow delete: if
        request.auth != null
        && resource.data.parentId == request.auth.uid;
    }

    // ─── Prayer logs ──────────────────────────────────────────────────────────
    // Structure: prayerLogs/{childId}/days/{dateStr}
    //
    // READ  — parent (verifies child ownership) or child device (UUID path)
    // WRITE — parent (full control) or child device writing valid prayer data
    match /prayerLogs/{childId}/days/{dateStr} {
      allow read: if
        // Authenticated parent reading their child's logs
        (request.auth != null &&
          get(/databases/$(database)/documents/children/$(childId)).data.parentId == request.auth.uid)
        // Child device reads its own logs by known UUID — UUID is not guessable
        || true;

      allow write: if
        // Authenticated parent can write (e.g. corrections)
        (request.auth != null &&
          get(/databases/$(database)/documents/children/$(childId)).data.parentId == request.auth.uid)
        // Child device writing prayer completions — validate schema
        || (
          request.resource.data.keys().hasOnly(
            ['fajr', 'dhuhr', 'asr', 'maghrib', 'isha', 'updatedAt']
          )
        );
    }

    // ─── Invite codes ─────────────────────────────────────────────────────────
    // GET  — anyone (child device needs to look up code from QR/share)
    // CREATE — authenticated parent only
    // UPDATE / DELETE — nobody (codes are permanent)
    match /inviteCodes/{code} {
      allow get: if true;
      allow list: if request.auth != null;
      allow create: if
        request.auth != null
        && request.resource.data.parentId == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
